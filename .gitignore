# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
*.lnk

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel

# Claude Code session data
.claude/

# Local-only data (StickyPassword export — contains real credentials, do not commit)
stickypass.xml
analyze-sticky.mjs

.env*.local

# Printable credential exports — plaintext passwords, never commit
/exports/

# One-off dry-run capture files
preview.txt
*.preview.txt
/scripts/import-inbox-log.txt

# Off-Vercel vault backups (DB JSON + blob inventory + optionally
# downloaded blob bytes). Contains decrypted-on-import family data. Never commit.
/backups/

.env*.local

# Local scratch — photo crops, one-off image runs, etc. Personal content,
# not part of the app.
/tmp/

# Owner-only fill-in sheet for finance entries. Will contain real account
# numbers, routing numbers, and card numbers once Lance edits it. NEVER
# commit. Generated by scripts/generate-finance-fillin.ts; consumed by
# scripts/apply-finance-fillin.ts.
/FINANCE-FILLIN.md
