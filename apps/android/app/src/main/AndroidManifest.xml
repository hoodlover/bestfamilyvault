<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="false"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.Material3.DayNight">

        <!-- Pairing / settings screen. Launcher entry point. -->
        <activity
            android:name=".PairActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Biometric gate. Launched from the autofill service's per-row
             PendingIntent; runs BiometricPrompt and (on success) returns
             the real credential values via EXTRA_AUTHENTICATION_RESULT.
             exported=false because only our own service should launch it.
             Translucent theme so the prompt floats over the original app
             instead of showing a blank screen behind it. -->
        <activity
            android:name=".AuthActivity"
            android:exported="false"
            android:theme="@style/Theme.CobbVault.Translucent" />

        <!-- Search-vault fallback. Bio-gated full-screen list of every
             credential the user can see, with live filter as they type.
             Launched from the autofill picker's "🔍 Search all my logins"
             row when the auto-match missed (typically native apps with
             cryptic package names). exported=false; same launch path
             as AuthActivity. -->
        <activity
            android:name=".SearchActivity"
            android:exported="false"
            android:theme="@style/Theme.Material3.DayNight" />

        <!-- The autofill provider. The system binds to it; only the OS may,
             hence the BIND_AUTOFILL_SERVICE permission. The meta-data points
             at the config (settings activity shown in system Autofill UI). -->
        <service
            android:name=".CobbVaultAutofillService"
            android:exported="true"
            android:permission="android.permission.BIND_AUTOFILL_SERVICE">
            <intent-filter>
                <action android:name="android.service.autofill.AutofillService" />
            </intent-filter>
            <meta-data
                android:name="android.autofill"
                android:resource="@xml/autofill_service" />
        </service>

    </application>
</manifest>
