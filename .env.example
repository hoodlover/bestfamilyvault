# Copy to .env.local and fill in.

# Neon Postgres URL (get from https://neon.tech project dashboard)
DATABASE_URL="postgres://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# Random string used to sign NextAuth JWTs. Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-me"

# NEXTAUTH_URL: only set this for LOCAL DEV in .env.local (e.g. http://localhost:3000).
# Do NOT set it on Vercel — Vercel auto-provides AUTH_TRUST_HOST and Auth.js v5
# infers the correct host from the request. A localhost value in production
# breaks every redirect (auth bounces the browser to http://localhost:3000).
# NEXTAUTH_URL="http://localhost:3000"

# ─── Email (self-serve password reset) ───────────────────────────────────────

# Resend API key — sign up at resend.com (free tier: 3000 emails/mo). Used by
# the password-reset flow. If unset, requesting a reset still appears to
# succeed for the user but no email actually goes out (the server logs the
# failure for an admin to investigate).
# RESEND_API_KEY="re_xxxxxxxxxxxxxxx"

# Optional: override the From address. Default is Resend's onboarding sender
# which works without DNS verification. Once cobbvault.com is verified in
# Resend, switch to e.g. "Cobb Family Vault <noreply@cobbvault.com>".
# RESEND_FROM="Cobb Family Vault <onboarding@resend.dev>"

# Public URL of this deployment, used in the password-reset email link. On
# Vercel this should be your custom-domain URL (e.g. https://www.cobbvault.com).
# Falls back to http://localhost:3000 in dev so the link works locally.
# NEXT_PUBLIC_APP_URL="https://www.cobbvault.com"

# ─── Cloud OCR (optional — powers scan/read-text buttons) ──────────────

# Google Vision API key. When set, CobbVault uses Google first for cheaper OCR.
# GOOGLE_VISION_API_KEY="AIza..."

# Anthropic API key — get one at console.anthropic.com. When Google Vision
# cannot read enough fields, CobbVault falls back to Claude Vision for smarter
# structured extraction. If both keys are unset, OCR buttons return a clear
# setup error.
# ANTHROPIC_API_KEY="sk-ant-..."

# ─── Demo deployment only — leave unset for real instances ────────────────────

# Set to "true" on a SEPARATE Vercel project pointed at a SEPARATE Neon DB.
# Enables: /demo landing page, demo banner, /api/cron/reset-demo endpoint.
# Without this, scripts/seed-demo.ts and the cron route both refuse to run.
# DEMO_MODE="true"

# Mirror of the above, exposed to the client so the banner + login CTA render.
# NEXT_PUBLIC_DEMO_MODE="true"

# Required if DEMO_MODE=true. Random string. Vercel cron sends it as
# Authorization: Bearer $CRON_SECRET; the reset endpoint validates this.
# CRON_SECRET="replace-me"

# ─── Branding overrides (optional, for white-labeled deployments) ─────────────

# Override the user-visible app name. Defaults to "The Cobb Vault" if unset.
# On the public demo project: NEXT_PUBLIC_APP_NAME="Before I Die Family Vault"
# NEXT_PUBLIC_APP_NAME="The Cobb Vault"
# NEXT_PUBLIC_APP_SHORT_NAME="Cobb Vault"
# NEXT_PUBLIC_APP_TAGLINE="Family secrets, safely kept."
